# SecureRAG backend configuration — copy to server/.env and fill in.
# Only JWT_SECRET_KEY is required; everything else has a safe default.

# --- Required ---
# Must be >=32 random chars and not a known placeholder, or the app refuses to start.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace_with_long_random_secret

# --- AI / threat-intel providers (optional; degrade gracefully if unset) ---
# Google Gemini key. If unset, the deterministic rule-based analyzer is used.
GEMINI_API_KEY=your_gemini_api_key_here
# AbuseIPDB key. If unset, IOC enrichment returns an honest "unavailable" state.
ABUSEIPDB_API_KEY=

# --- Bootstrap admin ---
# Weak values are ignored and a strong random password is generated + printed once.
DEFAULT_ADMIN_PASSWORD=change_me

# --- Server ---
HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
WAITRESS_THREADS=8
LOG_LEVEL=INFO
# Comma-separated allowed frontend origins (dev SPA runs on :3000).
CORS_ORIGINS=http://localhost:3000
# Set to false to disable the security response headers (default: on).
SECURITY_HEADERS_ENABLED=true

# --- Storage ---
CHROMA_DB_PATH=./chroma_store
SQLITE_TIMEOUT_SECONDS=30

# --- Input limits ---
MAX_UPLOAD_MB=50
MAX_QUERY_CHARS=10000
MAX_TOP_K=50
MAX_FEED_CHARS=1000000
MAX_SOURCE_CHARS=200

# --- Threat-intel cache TTLs (seconds) ---
ENRICH_TTL_SECONDS=86400
ENRICH_NEG_TTL_SECONDS=3600

# --- Login rate limiting ---
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW=60
